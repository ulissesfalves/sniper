<!doctype html><html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"/><link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png"/><link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"/><link rel="manifest" href="/site.webmanifest"/><meta name="msapplication-TileColor" content="#da532c"/><meta name="theme-color" content="#ffffff"/><meta property="og:url" content="https://celsius.network/"/><meta property="og:image" content="https://celsius.network/open-graph.png"/><meta name="twitter:image" content="https://celsius.network/open-graph.png"/><meta name="twitter:card" content="summary_large_image"/><meta name="twitter:site" content="@CelsiusNetwork"/><meta name="twitter:title" content="Celsius | Earn Bitcoin - Earn crypto with crypto lending"/><meta name="twitter:description" content="Earn BTC and 40+ other cryptocurrencies. Get a 1% cash loan using your crypto as collateral. Unbank Yourself with Celsius."/><meta name="description" content="Earn BTC and 40+ other cryptocurrencies. Get a 1% cash loan using your crypto as collateral. Unbank Yourself with Celsius."/><meta name="keywords" content="earn crypto, earn bitcoin, staking crypto, earn free cryptocurrency, crypto lending, coin lending, crypto lend, lending crypto, bitcoin calculator, cash loans, california loans, california crypto loans"/><meta property="og:title" content="Celsius | Earn Bitcoin - Earn crypto with crypto lending"/><script type="application/ld+json">{
        "@context": "https://schema.org",
        "@type": "Corporation",
        "name": "Celsius",
        "url": "https://celsius.network/",
        "logo": "https://celsius.network/android-chrome-512x512.png",
        "sameAs": [
          "https://twitter.com/CelsiusNetwork?ref_src=twsrc%5Egoogle%7Ctwcamp%5Eserp%7Ctwgr%5Eauthor",
          "https://www.youtube.com/channel/UC3yZY7UVs-zPKBuyNuPinbQ",
          "https://www.linkedin.com/company/celsiusnetwork/",
          "https://celsius.network/",
