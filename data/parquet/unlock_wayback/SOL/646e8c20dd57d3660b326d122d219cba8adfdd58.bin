built for immediate USDC transactions, fees that are fractions of a penny, and a net-zero environmental impact."},{"image":{"src":"https://cdn.builder.io/api/v1/image/assets%2Fce0c7323a97a4d91bd0baa7490ec9139%2F9fcfb8c2575946f0acfd2a37a30452ff"},"button":{"startIcon":"none","endIcon":"arrow-up-right","hierarchy":"link","url":"/developers/gaming","label":"Learn more about Gaming on Solana"},"featuredCompany":{"name":"Bladerite","logo":{"src":"https://cdn.builder.io/api/v1/image/assets%2Fce0c7323a97a4d91bd0baa7490ec9139%2Fda48f2fa7c8e449db24ce2cd95a44662","alt":"Bladerite Logo"}},"companies":[{"name":"BR1","logo":{"src":"https://cdn.builder.io/api/v1/image/assets%2Fce0c7323a97a4d91bd0baa7490ec9139%2Fc013b1f02bd84da6b1a27f40c3e8ebff","alt":"BR1 Logo"}},{"name":"Mini Royale Nations","logo":{"src":"https://cdn.builder.io/api/v1/image/assets%2Fce0c7323a97a4d91bd0baa7490ec9139%2Fe863f725ca6e41ca82bfb7068f4ab151","alt":"Mini Royale Nations Logo"}},{"name":"Star Atlas","logo":{"src":"https://cdn.builder.io/api/v1/image/assets%2Fce0c7323a97a4d91bd0baa7490ec9139%2F0f8844903dbb4548a32ce13d6ded6f5e","alt":"Star Atlas Logo"}},{"name":"Aurory","logo":{"src":"https://cdn.builder.io/api/v1/image/assets%2Fce0c7323a97a4d91bd0baa7490ec9139%2Fec76206730cf4e8c917014a231ae63d0","alt":"Aurory Logo"}},{"name":"Matchday","logo":{"src":"https://cdn.builder.io/api/v1/image/assets%2Fce0c7323a97a4d91bd0baa7490ec9139%2F54b7a29aeb1242f8a6fd72e2729ca518","alt":"Matchday Logo"}},{"name":"Seed Labs","logo":{"src":"https://cdn.builder.io/api/v1/image/assets%2Fce0c7323a97a4d91bd0baa7490ec9139%2F7a6645cb830042afb621ac40d30335e0","alt":"Seed Labs Logo"}},{"name":"Geno Pets","logo":{"src":"https://cdn.builder.io/api/v1/image/assets%2Fce0c7323a97a4d91bd0baa7490ec9139%2F52200d569bd648b1aaf51cee933dcb28","alt":"Geno Pets Logo"}}],"category":"Gaming","description":"Play and own. Bladerite, a free-to-play melee battle royale game, uses Solana to power its in-game item ownership system."},{"image":{"src":"https