appen across thousands of purpose-built L1s. Avalanche is where they&#39;re built. </p></div><a class="group/button button arrow transparent" href="/powered-by-avax" target="_self"> <wm-shape id="button" rounded="clamp(0.625rem, 0.196rem + 0.67vw, 1rem)" rounded-mobile="clamp(0.875rem, 0.803rem + 0.309vw, 1rem)" corner-rounded="clamp(0.25rem, 0.107rem + 0.223vw, 0.375rem)" corner-rounded-mobile="clamp(0.313rem, 0.276rem + 0.154vw, 0.375rem)" corner-size="clamp(1.125rem, -0.161rem + 2.009vw, 2.25rem)" corner-size-mobile="clamp(2rem, 1.855rem + 0.617vw, 2.25rem)"></wm-shape> 
Learn more
<span class="sr-only">Learn more about Powered by Avalanche</span> </a></div></div> </div> <script>(function(){const hud_delay = 4000;

	let initialCycle = false;
	let safari = false;

	const isSafari = () => {
		const ua = navigator.userAgent;
		return /^((?!chrome|android).)*safari/i.test(ua);
	};

	document.addEventListener("DOMContentLoaded", () => {
		let layers =
			window.innerWidth < 1025
				? document.querySelectorAll('[id^="layer-"]:nth-child(-n+5)')
				: document.querySelectorAll('[id^="layer-"]');
		let currentIndex = 0;

		isSafari() && (safari = true);

		function switchLayer() {
			let video = layers[currentIndex].querySelector("video");
			if (!video) return;

			// Hide current layer
			layers[currentIndex].classList.add("invisible");
			video.pause();
			video.currentTime = 0;

			// Move to next layer
			currentIndex = (currentIndex + 1) % layers.length;

			if (currentIndex === 0) {
				currentIndex++;
			}

			video = layers[currentIndex].querySelector("video");
			if (!video) return;

			video.currentTime = 0;
			video.play();
			layers[currentIndex].classList.remove("invisible");

			// Preload next layer
			const nextLayer = layers[currentIndex + 1]?.querySelector("video");
			if (!nextLayer) {
				initialCycle = true;
				return;
			}
			!safari && nextLayer.load();
			!initialCycle && (nextLayer.preload = "auto");
		}

		layers.forEach((layer, index) => {
			if (index === 0) return;

			const video = layer.querySelector("video");
			video.addEventListener("ended", switchLayer);
			//video.currentTime = 0;
		});

		let scaleTl = setTimeout(() => {
			layers[0].querySelector("video").play();
			layers[0].querySelector("video").addEventListener("ended", switchLayer);
			clearTimeout(scaleTl);
		}, 1500);

		const hudVideosWrapper = document.querySelectorAll(".hud-videos");

		hudVideosWrapper.forEach((wrapper) => {
			let hudVideos = wrapper.querySelectorAll("video");

			let hudTl = setTimeout(() => {
				hudVideos.forEach((video) => {
					video.currentTime = 0;
					video.play();
				});
				wrapper.classList.add("loaded");
				clearTimeout(hudTl);
			}, hud_delay);
		});
	});
})();</script> <div class="w-full h-full sm:will-change-transform col-start-1 lg:col-start-4 row-start-2 sm:row-start-2 lg:row-start-1 row-end-3 col-span-12 lg:col-span-6"> <div id="hero-sequencer" class="absolute w-full lg:w-[200%] mounted:w-full h-svh lg:h-full flex items-center justify-center fill-white dark:fill-dark bg-white dark:bg-dark sm:group-visible/section:bg-transparent rounded-4xl bottom-0 left-1/2 -translate-x-1/2 [clip-path:inset(0_0_0_0_round_var(--radius-4xl))] mounted:[clip-path:inset(calc(var(--hero-right-height)+var(--navbar-height)+1px)_0_calc(var(--hero-left-height)+1px)_0_round_var(--radius-4xl))] sm:mounted:[clip-path:inset(calc(var(--hero-right-height)+1px)_0_0_0_round_var(--radius-4xl))] lg:mounted:[clip-path:inset(var(--navbar-height)_1px_0_1px_round_var(--radius-4xl))]" style="transition: clip-path 2000ms 1000ms var(--ease-in-out-quart), width 2000ms 1000ms var(--ease-in-out-quart), background-color 300ms var(--ease-out-cubic), fill 300ms var(--ease-out-cubic);"> <wm-shape id="keep" rounded="clamp(1rem, -0.143rem + 1.786vw, 2rem)" rounded-mobile="clamp(1rem, 0.421rem + 2.469vw, 2rem)" corner-rounded="clamp(0.75rem, -0.107rem + 1.339vw, 1.5rem)" corner-rounded-mobile="clamp(0.75rem, -0.107rem + 1.339vw, 1.5rem)" corner-size="clamp(4.5rem, -0.071rem + 7.143vw, 8.5rem)" corner-size-mobile="clamp(3.5rem, 0.606rem + 12.346vw, 8.5rem)" stroke-width="1" corner="br" data-astro-cid-y3soregm="true"></wm-shape>  <div id="hero-sequencer-inner" class="absolute z-[1] -bottom-[calc(var(--navbar-height)/2)] lg:bottom-1/2 -translate-y-[calc(var(--navbar-height)/2)] sm:-translate-y-[calc(var(--navbar-height)/2)] lg:translate-y-1/2 mounted:-translate-y-[calc((var(--hero-left-height)-var(--hero-right-height))/2)] sm:mounted:translate-y-[calc((var(--hero-left-height)-var(--navbar-height))/2)] lg:mounted:translate-y-1/2 left-1/2 -translate-x-1/2 w-3/4 lg:w-[50vw] h-svh [transition:opacity_300ms_var(--ease-out-cubic),translate_2000ms_1000ms_var(--ease-in-out-qu