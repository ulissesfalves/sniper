n> </button> </div> </div> </div> </nav>  <script>(function(){const announcementUpdatedAt = "2025-08-11T14:50:32.232Z";
const display = false;

	let announcementBar;
	let announcementBarCloseButton;

	const checkAnnouncement = () => {
		try {
			const lastUpdate = localStorage.getItem("lastAnnouncementUpdate");

			if (!lastUpdate) {
				return true;
			}

			return new Date(announcementUpdatedAt) > new Date(lastUpdate);
		} catch (error) {
			console.error("Error checking announcement:", error);
			return true; // Show on error to be safe
		}
	};

	const readAnnouncement = () => {
		try {
			// Store the current announcement's updatedAt timestamp
			localStorage.setItem("lastAnnouncementUpdate", announcementUpdatedAt);

			// Hide the banner
			announcementBar?.classList.add("hide");
		} catch (error) {
			console.error("Error dismissing announcement:", error);
			// Still hide the banner even if localStorage fails
			announcementBar?.classList.add("hide");
		}
	};

	document.addEventListener("DOMContentLoaded", () => {
		announcementBar = document.getElementById("announcement-bar");
		announcementBarCloseButton = document.getElementById("announcement-bar-close-button");

		// Initialize banner visibility
		if (announcementBar && announcementUpdatedAt && display) {
			if (!checkAnnouncement()) {
				announcementBar.classList.add("hide");
			}

			announcementBarCloseButton?.addEventListener("click", readAnnouncement);
		}
	});
})();</script>  <div class="fixed top-0 left-0 w-screen h-dvh bg-black/50 z-100 pointer-events-none invisible opacity-0 [.visible&]:pointer-events-auto [.visible&]:visible [.visible&]:opacity-100 transition-all duration-500 [.visible&]:ease-in-out-cubic ease-out-cubic" id="overlay"></div> <main class="flex flex-col gap-px overflow-x-clip">  <script type="module">const e=document.getElementById("hero-inner"),o=document.getElementById("hero-left-inner"),r=document.getElementById("hero-right-inner"),t=()=>{const n=o.clientHeight,h=r.clientHeight;e.style.setProperty("--hero-left-height",`${n}px`),e.style.setProperty("--hero-right-height",`${h}px`)};t();window.addEventListener("resize",t);</script> <section id="hero" class="relative w-full h-svh gap-md flex items-end justify-center pt-(--navbar-height) sm:pt-0"> <div id="hero-inner" class="group/section animate-in-view relative shrink-0 w-full h-full sm:h-svh grid grid-cols-12 grid-rows-[min-content_1fr_min-content] sm:grid-rows-[min-content_1fr] gap-x-px lg:gap-0"> <div id="hero-left" class="col-start-1 row-start-3 sm:row-start-1 row-end-4 sm:row-end-2 lg:row-end-3 col-span-12 sm:col-span-6 lg:col-span-3 h-[200%] lg:h-auto w-full lg:w-[200%] self-start sm:self-end lg:self-auto justify-self-end transition-[clip-path] duration-2000 delay-1000 ease-in-out-quart [clip-path:inset(50%_0_0_0_round_var(--radius-4xl))] mounted:[clip-path:inset(0_0_50%_0_round_var(--radius-4xl))] sm:[clip-path:inset(0_0_50%_0_round_var(--radius-4xl))] sm:mounted:[clip-path:inset(calc(50%+var(--navbar-height))_0_0_0_round_var(--radius-4xl))] lg:[clip-path:inset(0_50%_0_0_round_var(--radius-4xl))] lg:mounted:[clip-path:inset(var(--navbar-height)_0_0_50%_round_var(--radius-4xl))] flex items-start sm:items-end lg:items-start justify-end lg:grid lg:grid-cols-2 lg:grid-rows-2 lg:justify-start"> <div id="hero-left-inner" class="h-1/2 w-full z-[2] bg-white dark:bg-dark flex flex-col items-start justify-start p-md sm:pt-[calc(var(--navbar-height)+var(--pa