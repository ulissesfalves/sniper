ure/adr-076-tx-malleability\"}]},{\"group\":\"RFCs\",\"pages\":[{\"title\":\"Requests for Comments\",\"description\":\"Version: v0.53\",\"href\":\"/sdk/v0.53/build/rfc\"},{\"title\":\"RFC Creation Process\",\"description\":null,\"href\":\"/sdk/v0.53/build/rfc/PROCESS\"},{\"title\":\"RFC 001: Transaction Validation\",\"description\":\"2023-03-12: Proposed\",\"href\":\"/sdk/v0.53/build/rfc/rfc-001-tx-validation\"},{\"title\":null,\"description\":null,\"href\":\"/sdk/v0.53/build/rfc/rfc-template\"}]},{\"group\":\"Specifications\",\"pages\":[{\"title\":\"Specifications\",\"description\":\"Version: v0.53\",\"href\":\"/sdk/v0.53/build/spec\"},{\"title\":\"Specification of Modules\",\"description\":\"This file intends to outline the common structure for specifications within this directory.\",\"href\":\"/sdk/v0.53/build/spec/SPEC_MODULE\"},{\"title\":\"What is an SDK standard?\",\"description\":null,\"href\":\"/sdk/v0.53/build/spec/SPEC_STANDARD\"},{\"group\":\"Store\",\"pages\":[{\"title\":\"Store\",\"description\":null,\"href\":\"/sdk/v0.53/build/spec/store/store\"},{\"title\":\"Inter-block Cache\",\"description\":null,\"href\":\"/sdk/v0.53/build/spec/store/interblock-cache\"}]}]},{\"group\":\"API Documentation\",\"pages\":[{\"title\":\"Protobuf Documentation\",\"description\":\"See Cosmos SDK Buf Proto-docs\",\"href\":\"/sdk/v0.53/learn/advanced/proto-docs\"}]}]},{\"group\":\"Security\",\"pages\":[{\"title\":\"Security and Maintenance Policy\",\"description\":\"Security and maintenance policy documentation for the Cosmos Stack\",\"href\":\"/sdk/v0.53/security/security-policy\"},{\"title\":\"Bug Bounty Program\",\"description\":\"Security and maintenance policy documentation for the Cosmos Stack\",\"href\":\"/sdk/v0.53/security/bug-bounty\"},{\"title\":\"Security Audits\",\"description\":\"Security audits and transparency reports for Cosmos Stack components\",\"href\":\"/sdk/v0.53/security/audits\"}]}]},{\"tab\":\"Release Notes\",\"pages\":[{\"title\":\"Release Notes\",\"description\":\"Release history and changelog for Cosmos SDK\",\"mode\":\"wide\",\"href\":\"/sdk/v0.53/changelog/release-notes\"}]}]},{\"version\":\"next\",\"tag\":\"Unreleased\",\"tabs\":[{\"tab\":\"Cosmos SDK\",\"groups\":[{\"group\":\"Learn\",\"pages\":[{\"noindex\":true,\"title\":\"Cosmos SDK Documentation\",\"description\":\"Version: v0.53\",\"href\":\"/sdk/next/learn\"},{\"group\":\"Overview\",\"expanded\":true,\"pages\":[{\"noindex\":true,\"title\":\"The Cosmos Stack\",\"description\":\"Understanding the modular architecture of the Cosmos blockchain stack\",\"href\":\"/sdk/next/learn/intro/cosmos-stack\"},{\"noindex\":true,\"title\":\"What is the Cosmos SDK\",\"description\":null,\"href\":\"/sdk/next/learn/intro/overview\"},{\"noindex\":true,\"title\":\"Application-Specific Blockchains\",\"description\":null,\"href\":\"/sdk/next/learn/intro/why-app-specific\"},{\"noindex\":true,\"title\":\"Introduction to Blockchains\",\"description\":\"Learn the fundamentals of blockchains, state machines, and how Cosmos SDK applications work.\",\"href\":\"/sdk/next/learn/intro/blockchain-basics\"},{\"noindex\":true,\"title\":\"Cosmos SDK Architecture\",\"description\":\"How Cosmos SDK implements blockchains through separation of consensus, interface, and application logic.\",\"href\":\"/sdk/next/learn/intro/sdk-app-architecture\"},{\"noindex\":true,\"title\":\"Main Components of the Cosmos SDK\",\"description\":null,\"href\":\"/sdk/next/learn/intro/sdk-design\"}]},{\"group\":\"Fundamentals\",\"pages\":[{\"noindex\":true,\"title\":\"Anatomy of a Cosmos SDK Application\",\"description\":null,\"href\":\"/sdk/next/learn/beginner/app-anatomy\"},{\"noindex\":true,\"title\":\"Transaction Lifecycle\",\"description\":null,\"href\":\"/sdk/next/learn/beginner/tx-lifecycle\"},{\"noindex\":true,\"title\":\"Query Lifecycle\",\"description\":null,\"href\":\"/sdk/next/learn/beginner/query-lifecycle\"},{\"noindex\":true,\"title\":\"Accounts\",\"description\":null,\"href\":\"/sdk/next/learn/beginner/accounts\"},{\"noindex\":true,\"title\":\"Gas and Fees\",\"description\":null,\"href\":\"/sdk/next/learn/beginner/gas-fees\"}]},{\"group\":\"In-depth Concepts\",\"pages\":[{\"group\":\"Core Components\",\"expanded\":true,\"pages\":[{\"noindex\":true,\"title\":\"BaseApp\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/baseapp\"},{\"noindex\":true,\"title\":\"Transactions\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/transactions\"},{\"noindex\":true,\"title\":\"Context\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/context\"},{\"noindex\":true,\"title\":\"Encoding\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/encoding\"},{\"noindex\":true,\"title\":\"Store\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/store\"},{\"title\":\"Address Encoding\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/spec/addresses/bech32\"}]},{\"group\":\"Security \u0026 Execution\",\"expanded\":true,\"pages\":[{\"noindex\":true,\"title\":\"Object-Capability Model\",\"description\":\"When thinking about security, it is good to start with a specific threat model. Our threat model is the following:\",\"href\":\"/sdk/next/learn/advanced/ocap\"},{\"noindex\":true,\"title\":\"RunTx recovery middleware\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/runtx_middleware\"}]},{\"noindex\":true,\"title\":\"Events\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/events\"},{\"noindex\":true,\"title\":\"Node Client (Daemon)\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/node\"},{\"group\":\"Chain CLI \u0026 Endpoints\",\"expanded\":true,\"pages\":[{\"noindex\":true,\"title\":\"gRPC, REST, and CometBFT Endpoints\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/grpc_rest\"},{\"noindex\":true,\"title\":\"Command-Line Interface\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/cli\"},{\"noindex\":true,\"title\":\"AutoCLI\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/autocli\"}]}]}]},{\"group\":\"Building a Chain\",\"pages\":[{\"noindex\":true,\"title\":\"Overview\",\"description\":\"Version: v0.53\",\"href\":\"/sdk/next/build\"},{\"group\":\"Chain Development\",\"pages\":[{\"title\":\"Overview of app.go\",\"description\":\"Understanding the structure and purpose of the app.go file in Cosmos SDK applications\",\"noindex\":true,\"href\":\"/sdk/next/build/building-apps/app-go\"},{\"title\":\"What is runtime?\",\"description\":\"The runtime package in the Cosmos SDK provides a flexible framework for configuring and managing blockchain applications. It serves as the foundation for creating modular blockchain applications using a declarative configuration approach.\",\"noindex\":true,\"href\":\"/sdk/next/build/building-apps/runtime\"},{\"title\":\"Overview of app_di.go\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-apps/app-go-di\"},{\"title\":\"Application Mempool\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-apps/app-mempool\"},{\"title\":\"Chain Upgrades\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-apps/app-upgrade\"},{\"title\":\"Vote Extensions\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-apps/vote-extensions\"},{\"title\":\"Application Testnets\",\"description\":\"Building an application is complicated and requires a lot of testing. The Cosmos SDK provides a way to test your application in a real-world environment: a testnet.\",\"noindex\":true,\"href\":\"/sdk/next/build/building-apps/app-testnet\"}]},{\"noindex\":true,\"title\":\"Building a Transaction\",\"description\":\"These are the steps to build, sign and broadcast a transaction using v2 semantics.\",\"href\":\"/sdk/next/tutorials/transactions/building-a-transaction\"},{\"noindex\":true,\"title\":\"Cosmos Blockchain Simulator\",\"description\":\"The Cosmos SDK offers a full-fledged simulation framework to fuzz test every message defined by a module.\",\"href\":\"/sdk/next/learn/advanced/simulation\"},{\"group\":\"SDK Packages\",\"pages\":[{\"title\":\"Packages\",\"description\":\"Version: v0.53\",\"noindex\":true,\"href\":\"/sdk/next/build/packages\"},{\"title\":\"Depinject\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/packages/depinject\"},{\"title\":\"Collections\",\"description\":\"Collections is a library meant to simplify the experience with respect to module state handling.\",\"noindex\":true,\"href\":\"/sdk/next/build/packages/collections\"}]},{\"group\":\"ABCI\",\"pages\":[{\"title\":\"Introduction\",\"description\":\"ABCI, Application Blockchain Interface is the interface between CometBFT and the application. More information about ABCI can be found here. CometBFT version 0.38 included a new version of ABCI (called ABCI 2.0) which added several new methods.\",\"noindex\":true,\"href\":\"/sdk/next/build/abci/introduction\"},{\"title\":\"Prepare Proposal\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/abci/prepare-proposal\"},{\"title\":\"Process Proposal\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/abci/process-proposal\"},{\"title\":\"Vote Extensions\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/abci/vote-extensions\"},{\"title\":\"CheckTx\",\"description\":\"CheckTx is called by the BaseApp when comet receives a transaction from a client, over the p2p network or RPC. The CheckTx method is responsible for validating the transaction and returning an error if the transaction is invalid.\",\"noindex\":true,\"href\":\"/sdk/next/build/abci/checktx\"}]}]},{\"group\":\"Building a Module\",\"pages\":[{\"group\":\"Module Development\",\"pages\":[{\"title\":\"Introduction to Cosmos SDK Modules\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/intro\"},{\"group\":\"Core Architecture\",\"expanded\":true,\"pages\":[{\"title\":\"Recommended Folder Structure\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/structure\"},{\"title\":\"Module Manager\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/module-manager\"},{\"title\":\"Keepers\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/keeper\"},{\"title\":\"Module Interfaces\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/module-interfaces\"}]},{\"group\":\"Messages \u0026 Queries\",\"expanded\":true,\"pages\":[{\"title\":\"Messages and Queries\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/messages-and-queries\"},{\"title\":\"Msg Services\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/msg-services\"},{\"title\":\"Query Services\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/query-services\"},{\"title\":\"ProtocolBuffer Annotations\",\"description\":\"This document explains the various protobuf scalars that have been added to make working with protobuf easier for Cosmos SDK application developers\",\"noindex\":true,\"href\":\"/sdk/next/build/building-modules/protobuf-annotations\"}]},{\"group\":\"Lifecycle \u0026 State\",\"expanded\":true,\"pages\":[{\"title\":\"Module Genesis\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/genesis\"},{\"title\":\"PreBlocker\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/preblock\"},{\"title\":\"BeginBlocker and EndBlocker\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/beginblock-endblock\"},{\"title\":\"Invariants\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/invariants\"}]},{\"group\":\"Advanced Development\",\"expanded\":true,\"pages\":[{\"title\":\"Modules depinject-ready\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/depinject\"},{\"title\":\"Errors\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/errors\"},{\"title\":\"Upgrading Modules\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/upgrade\"},{\"title\":\"Testing\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/testing\"},{\"title\":\"Module Simulation\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/building-modules/simulator\"}]}]},{\"group\":\"Open Source Modules\",\"pages\":[{\"title\":\"List of Modules\",\"description\":\"Here are some production-grade modules that can be used in Cosmos SDK applications, along with their respective documentation.\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/modules\"},{\"group\":\"x/auth\",\"pages\":[{\"title\":\"x/auth\",\"description\":\"This document specifies the auth module of the Cosmos SDK.\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/auth/auth\"},{\"title\":\"x/auth/vesting\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/modules/auth/vesting\"},{\"title\":\"x/auth/tx\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/modules/auth/tx\"}]},{\"title\":\"x/authz\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/modules/authz/README\"},{\"title\":\"x/bank\",\"description\":\"This document specifies the bank module of the Cosmos SDK.\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/bank/README\"},{\"title\":\"x/consensus\",\"description\":\"Functionality to modify CometBFT's ABCI consensus params.\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/consensus/README\"},{\"title\":\"x/crisis\",\"description\":\"NOTE: x/crisis is deprecated as of Cosmos SDK v0.53 and will be removed in the next release.\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/crisis/README\"},{\"title\":\"x/distribution\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/modules/distribution/README\"},{\"title\":\"x/epochs\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/modules/epochs/README\"},{\"title\":\"x/evidence\",\"description\":\"Concepts State Messages Events Parameters BeginBlock Client CLI REST gRPC\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/evidence/README\"},{\"title\":\"x/feegrant\",\"description\":\"This document specifies the fee grant module. For the full ADR, please see Fee Grant ADR-029.\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/feegrant/README\"},{\"title\":\"x/gov\",\"description\":\"This paper specifies the Governance module of the Cosmos SDK, which was first described in the Cosmos Whitepaper in June 2016.\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/gov/README\"},{\"title\":\"x/group\",\"description\":\"The following documents specify the group module.\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/group/README\"},{\"title\":\"x/mint\",\"description\":\"The x/mint module handles the regular minting of new tokens in a configurable manner.\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/mint/README\"},{\"title\":\"x/nft\",\"description\":\"## Abstract\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/nft/README\"},{\"title\":\"x/params\",\"description\":\"NOTE: x/params is deprecated as of Cosmos SDK v0.53 and will be removed in the next release.\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/params/README\"},{\"title\":\"x/protocolpool\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/modules/protocolpool/README\"},{\"title\":\"x/slashing\",\"description\":\"This section specifies the slashing module of the Cosmos SDK, which implements functionality first outlined in the Cosmos Whitepaper in June 2016.\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/slashing/README\"},{\"title\":\"x/staking\",\"description\":\"This paper specifies the Staking module of the Cosmos SDK that was first described in the Cosmos Whitepaper in June 2016.\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/staking/README\"},{\"title\":\"x/upgrade\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/modules/upgrade/README\"},{\"title\":\"x/circuit\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/modules/circuit/README\"},{\"title\":\"x/genutil\",\"description\":\"The genutil package contains a variety of genesis utility functionalities for usage within a blockchain application. Namely:\",\"noindex\":true,\"href\":\"/sdk/next/build/modules/genutil/README\"}]}]},{\"group\":\"Run a Node\",\"pages\":[{\"noindex\":true,\"title\":\"Node Tutorial\",\"description\":\"Version: v0.53\",\"href\":\"/sdk/next/tutorials\"},{\"group\":\"Get Started\",\"pages\":[{\"noindex\":true,\"title\":\"Prerequisites\",\"description\":null,\"href\":\"/sdk/next/user/run-node/prerequisites\"},{\"noindex\":true,\"title\":\"Setting up the keyring\",\"description\":null,\"href\":\"/sdk/next/user/run-node/keyring\"},{\"noindex\":true,\"title\":\"Running a Node\",\"description\":null,\"href\":\"/sdk/next/user/run-node/run-node\"},{\"noindex\":true,\"title\":\"Interacting with a Node\",\"description\":null,\"href\":\"/sdk/next/user/run-node/interact-node\"},{\"noindex\":true,\"title\":\"Generating, Signing and Broadcasting Transactions\",\"description\":null,\"href\":\"/sdk/next/user/run-node/txs\"}]},{\"group\":\"Testnet \u0026 Production\",\"pages\":[{\"noindex\":true,\"title\":\"Configuration\",\"description\":\"This documentation refers to the app.toml. If you'd like to read about the config.toml, please visit the CometBFT docs.\",\"href\":\"/sdk/next/learn/advanced/config\"},{\"noindex\":true,\"title\":\"Running a Testnet\",\"description\":null,\"href\":\"/sdk/next/user/run-node/run-testnet\"},{\"noindex\":true,\"title\":\"Running in Production\",\"description\":null,\"href\":\"/sdk/next/user/run-node/run-production\"}]},{\"noindex\":true,\"title\":\"Telemetry\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/telemetry\"},{\"noindex\":true,\"title\":\"Log v2\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/log\"},{\"group\":\"Upgrades \u0026 Migrations\",\"pages\":[{\"noindex\":true,\"title\":\"In-Place Store Migrations\",\"description\":null,\"href\":\"/sdk/next/learn/advanced/upgrade\"},{\"title\":\"Cosmovisor\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/tooling/cosmovisor\"}]}]},{\"group\":\"How-to Guides\",\"pages\":[{\"noindex\":true,\"title\":\"Guides Intro\",\"description\":\"Version: v0.53\",\"href\":\"/sdk/next/user\"},{\"group\":\"Vote Extensions - Auction Front-Running\",\"pages\":[{\"noindex\":true,\"title\":\"Getting Started\",\"description\":\"- Getting Started - Understanding Front-Running - Mitigating Front-running with Vote Extensions - Demo of Mitigating Front-Running\",\"href\":\"/sdk/next/tutorials/vote-extensions/auction-frontrunning/getting-started\"},{\"noindex\":true,\"title\":\"Understanding Front-Running and more\",\"description\":\"Blockchain technology is vulnerable to practices that can affect the fairness and security of the network. Two such practices are front-running and Maximal Extractable Value (MEV), which are important for blockchain participants to understand.\",\"href\":\"/sdk/next/tutorials/vote-extensions/auction-frontrunning/understanding-frontrunning\"},{\"noindex\":true,\"title\":\"Mitigating Front-running with Vote Extensions\",\"description\":\"Prerequisites Implementing Structs for Vote Extensions Implementing Handlers and Configuring Handlers\",\"href\":\"/sdk/next/tutorials/vote-extensions/auction-frontrunning/mitigating-front-running-with-vote-extensions\"},{\"noindex\":true,\"title\":\"Mitigating Front-running with Vote Extensions\",\"description\":\"- Prerequisites - Implementing Structs for Vote Extensions - Implementing Handlers and Configuring Handlers\",\"href\":\"/sdk/next/tutorials/vote-extensions/auction-frontrunning/mitigating-front-running-with-vote-extesions\"},{\"noindex\":true,\"title\":\"Demo of Mitigating Front-Running with Vote Extensions\",\"description\":null,\"href\":\"/sdk/next/tutorials/vote-extensions/auction-frontrunning/demo-of-mitigating-front-running\"}]},{\"group\":\"Vote Extensions - Oracle\",\"pages\":[{\"noindex\":true,\"title\":\"Getting Started\",\"description\":\"What is an Oracle? Implementing Vote Extensions Testing the Oracle Module\",\"href\":\"/sdk/next/tutorials/vote-extensions/oracle/getting-started\"},{\"noindex\":true,\"title\":\"What is an Oracle?\",\"description\":null,\"href\":\"/sdk/next/tutorials/vote-extensions/oracle/what-is-an-oracle\"},{\"noindex\":true,\"title\":\"Implementing Vote Extensions\",\"description\":\"First we’ll create the OracleVoteExtension struct, this is the object that will be marshaled as bytes and signed by the validator.\",\"href\":\"/sdk/next/tutorials/vote-extensions/oracle/implementing-vote-extensions\"},{\"noindex\":true,\"title\":\"Testing the Oracle Module\",\"description\":\"We will guide you through the process of testing the Oracle module in your application. The Oracle module uses vote extensions to provide current price data. If you would like to see the complete working oracle module please see here.\",\"href\":\"/sdk/next/tutorials/vote-extensions/oracle/testing-oracle\"}]}]},{\"group\":\"v0.54 Upgrade\",\"pages\":[{\"title\":\"Cosmos SDK v0.54 Release Overview\",\"description\":\"The largest performance release in Cosmos SDK history; parallel execution, application-side mempools, a next-generation P2P layer, a unified observability stack, and a new Proof of Authority module.\",\"href\":\"/sdk/next/upgrade/v054\"},{\"title\":\"v0.54 Upgrade Guide\",\"description\":\"Reference for upgrading from v0.53 to v0.54 of Cosmos SDK\",\"href\":\"/sdk/next/upgrade/upgrade\"},{\"noindex\":true,\"title\":\"Block-STM: Parallel Transaction Execution\",\"description\":null,\"href\":\"/sdk/next/experimental/blockstm\"}]},{\"group\":\"Tooling\",\"pages\":[{\"title\":\"Tool Guide\",\"description\":\"Version: v0.53\",\"noindex\":true,\"href\":\"/sdk/next/build/tooling\"},{\"title\":\"Protocol Buffers\",\"description\":\"It is known that Cosmos SDK uses protocol buffers extensively, this document is meant to provide a guide on how it is used in the cosmos-sdk.\",\"noindex\":true,\"href\":\"/sdk/next/build/tooling/protobuf\"},{\"title\":\"Confix\",\"description\":\"Confix is a configuration management tool that allows you to manage your configuration via CLI.\",\"noindex\":true,\"href\":\"/sdk/next/build/tooling/confix\"}]},{\"group\":\"Reference\",\"pages\":[{\"group\":\"Migrations\",\"pages\":[{\"title\":\"SDK Migrations\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/migrations/intro\"},{\"title\":\"Upgrade Reference\",\"description\":\"This document provides a quick reference for the upgrades from v0.50.x to v0.53.x of Cosmos SDK.\",\"noindex\":true,\"href\":\"/sdk/next/build/migrations/upgrade-reference\"},{\"title\":\"Upgrade Guide\",\"description\":\"This document provides a full guide for upgrading a Cosmos SDK chain from v0.50.x to v0.53.x.\",\"noindex\":true,\"href\":\"/sdk/next/build/migrations/upgrade-guide\"}]},{\"group\":\"ADRs\",\"pages\":[{\"title\":\"Architecture Decision Records (ADR)\",\"description\":\"This is a location to record all high-level architecture decisions in the Cosmos-SDK.\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/README\"},{\"title\":\"ADR Creation Process\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/architecture/PROCESS\"},{\"title\":\"ADR 002: SDK Documentation Structure\",\"description\":\"There is a need for a scalable structure of the Cosmos SDK documentation. Current documentation includes a lot of non-related Cosmos SDK material, is difficult to maintain and hard to follow as a user.\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-002-docs-structure\"},{\"title\":\"ADR 003: Dynamic Capability Store\",\"description\":\"12 December 2019: Initial version 02 April 2020: Memory Store Revisions\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-003-dynamic-capability-store\"},{\"title\":\"ADR 004: Split Denomination Keys\",\"description\":\"2020-01-08: Initial version 2020-01-09: Alterations to handle vesting accounts 2020-01-14: Updates from review feedback 2020-01-30: Updates from implementation\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-004-split-denomination-keys\"},{\"title\":\"ADR 006: Secret Store Replacement\",\"description\":\"July 29th, 2019: Initial draft September 11th, 2019: Work has started November 4th: Cosmos SDK changes merged in November 18th: Gaia changes merged in\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-006-secret-store-replacement\"},{\"title\":\"ADR 007: Specialization Groups\",\"description\":\"2019 Jul 31: Initial Draft\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-007-specialization-groups\"},{\"title\":\"ADR 008: Decentralized Computer Emergency Response Team (dCERT) Group\",\"description\":\"2019 Jul 31: Initial Draft\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-008-dCERT-group\"},{\"title\":\"ADR 009: Evidence Module\",\"description\":\"2019 July 31: Initial draft 2019 October 24: Initial implementation\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-009-evidence-module\"},{\"title\":\"ADR 010: Modular AnteHandler\",\"description\":\"2019 Aug 31: Initial draft 2021 Sep 14: Superseded by ADR-045\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-010-modular-antehandler\"},{\"title\":\"ADR 011: Generalize Genesis Accounts\",\"description\":\"2019-08-30: initial draft\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-011-generalize-genesis-accounts\"},{\"title\":\"ADR 012: State Accessors\",\"description\":\"2019 Sep 04: Initial draft\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-012-state-accessors\"},{\"title\":\"ADR 013: Observability\",\"description\":\"20-01-2020: Initial Draft\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-013-metrics\"},{\"title\":\"ADR 14: Proportional Slashing\",\"description\":\"2019-10-15: Initial draft 2020-05-25: Removed correlation root slashing 2020-07-01: Updated to include S-curve function instead of linear\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-014-proportional-slashing\"},{\"title\":\"ADR 016: Validator Consensus Key Rotation\",\"description\":\"2019 Oct 23: Initial draft 2019 Nov 28: Add key rotation fee\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-016-validator-consensus-key-rotation\"},{\"title\":\"ADR 17: Historical Header Module\",\"description\":\"26 November 2019: Start of first version 2 December 2019: Final draft of first version\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-017-historical-header-module\"},{\"title\":\"ADR 18: Extendable Voting Periods\",\"description\":\"1 January 2020: Start of first version\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-018-extendable-voting-period\"},{\"title\":\"ADR 019: Protocol Buffer State Encoding\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/architecture/adr-019-protobuf-state-encoding\"},{\"title\":\"ADR 020: Protocol Buffer Transaction Encoding\",\"noindex\":true,\"description\":null,\"href\":\"/sdk/next/build/architecture/adr-020-protobuf-transaction-encoding\"},{\"title\":\"ADR 021: Protocol Buffer Query Encoding\",\"description\":\"2020 March 27: Initial Draft\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-021-protobuf-query-encoding\"},{\"title\":\"ADR 022: Custom BaseApp panic handling\",\"description\":\"2020 Apr 24: Initial Draft 2021 Sep 14: Superseded by ADR-045\",\"noindex\":true,\"href\":\"/sdk/next/build/architecture/adr-022-custom-panic-handling\"},{\"title\":\"ADR 023: Protocol Buffer Naming and Versioning Conventions\",\"description\":\"2020 April 27: Initial Draft 2020 August 5: Update guidelines\",\