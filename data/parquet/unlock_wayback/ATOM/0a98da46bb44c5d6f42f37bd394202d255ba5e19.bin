ocs/core/state-sync\"},{\"title\":\"RPC\",\"order\":9,\"description\":null,\"href\":\"/cometbft/v0.38/docs/core/RPC\"},{\"title\":\"Subscribing to events via Websocket\",\"order\":7,\"description\":null,\"href\":\"/cometbft/v0.38/docs/core/Subscribing-to-events-via-Websocket\"},{\"title\":\"Metrics\",\"order\":5,\"description\":null,\"href\":\"/cometbft/v0.38/docs/core/metrics\"},{\"title\":\"Validators\",\"order\":6,\"description\":null,\"href\":\"/cometbft/v0.38/docs/core/Validators\"},{\"title\":\"Light Client\",\"order\":13,\"description\":null,\"href\":\"/cometbft/v0.38/docs/core/light-client\"},{\"title\":\"Block Structure\",\"order\":8,\"description\":null,\"href\":\"/cometbft/v0.38/docs/core/block-structure\"},{\"title\":\"How to read logs\",\"order\":7,\"description\":null,\"href\":\"/cometbft/v0.38/docs/core/how-to-read-logs\"}]},{\"group\":\"Developer Tools\",\"pages\":[{\"title\":\"Overview\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/docs/tools/Overview\"},{\"title\":\"Debugging\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/docs/tools/debugging\"}]},{\"group\":\"Networks\",\"pages\":[{\"title\":\"Docker Compose\",\"order\":2,\"description\":null,\"href\":\"/cometbft/v0.38/docs/networks/Docker-Compose\"}]},{\"group\":\"CometBFT Quality Assurance\",\"pages\":[{\"title\":\"CometBFT Quality Assurance\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/docs/qa/CometBFT-qa\"},{\"title\":\"Method\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/docs/qa/Method\"},{\"order\":1,\"parent\":{\"title\":\"CometBFT QA Results v0.38.x\",\"description\":\"This is a report on the results obtained when running CometBFT v0.38.x on testnets\",\"order\":5},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/docs/qa/CometBFT-QA-38\"},{\"order\":1,\"parent\":{\"title\":\"CometBFT QA Results v0.37.x\",\"description\":\"This is a report on the results obtained when running CometBFT v0.37.x on testnets\",\"order\":5},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/docs/qa/CometBFT-QA-37\"},{\"order\":1,\"parent\":{\"title\":\"CometBFT QA Results v0.34.x\",\"description\":\"This is a report on the results obtained when running v0.34.x on testnets\",\"order\":3},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/docs/qa/CometBFT-QA-34\"},{\"order\":1,\"parent\":{\"title\":\"Tendermint Core QA Results v0.37.x\",\"description\":\"This is a report on the results obtained when running TM v0.37.x on testnets\",\"order\":4},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/docs/qa/TMCore-QA-37\"},{\"order\":1,\"parent\":{\"title\":\"Tendermint Core QA Results v0.34.x\",\"description\":\"This is a report on the results obtained when running v0.34.x on testnets\",\"order\":2},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/docs/qa/TMCore-QA-34\"}]}]}]},{\"tab\":\"Specification\",\"groups\":[{\"group\":\"CometBFT Spec\",\"pages\":[{\"order\":1,\"title\":\"Overview\",\"parent\":{\"title\":\"Spec\",\"order\":7},\"description\":null,\"href\":\"/cometbft/v0.38/spec/CometBFT-Spec\"},{\"group\":\"Core\",\"pages\":[{\"order\":1,\"parent\":{\"title\":\"Core\",\"order\":3},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/spec/core/Overview\"},{\"title\":\"Data Structures\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/spec/core/Data_structures\"},{\"title\":\"Encoding\",\"order\":2,\"description\":null,\"href\":\"/cometbft/v0.38/spec/core/encoding\"},{\"title\":\"Genesis\",\"order\":3,\"description\":null,\"href\":\"/cometbft/v0.38/spec/core/genesis\"},{\"title\":\"State\",\"order\":4,\"description\":null,\"href\":\"/cometbft/v0.38/spec/core/state\"}]},{\"group\":\"ABCI++\",\"pages\":[{\"order\":1,\"parent\":{\"title\":\"ABCI++\",\"order\":3},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/spec/abci/Overview\"},{\"order\":1,\"title\":\"Overview and basic concepts\",\"description\":null,\"href\":\"/cometbft/v0.38/spec/abci/Outline\"},{\"order\":2,\"title\":\"Methods\",\"description\":null,\"href\":\"/cometbft/v0.38/spec/abci/Methods\"},{\"order\":3,\"title\":\"Requirements for the Application\",\"description\":null,\"href\":\"/cometbft/v0.38/spec/abci/Requirements-for-the-Application\"},{\"order\":4,\"title\":\"CometBFT's expected behavior\",\"description\":null,\"href\":\"/cometbft/v0.38/spec/abci/CometBFTs-expected-behavior\"},{\"order\":5,\"title\":\"Client and Server\",\"description\":null,\"href\":\"/cometbft/v0.38/spec/abci/Client-and-server\"},{\"order\":6,\"title\":\"ABCI++ extra\",\"description\":null,\"href\":\"/cometbft/v0.38/spec/abci/Introduction\"}]},{\"group\":\"Consensus\",\"pages\":[{\"order\":1,\"parent\":{\"title\":\"Consensus\",\"order\":4},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/spec/consensus/Overview\"},{\"title\":\"Consensus Paper\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/spec/consensus/Consensus-Paper\"},{\"title\":\"Byzantine Consensus Algorithm\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/spec/consensus/Byzantine-Consensus-Algorithm\"},{\"order\":1,\"parent\":{\"title\":\"Light Client\",\"order\":false},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/spec/consensus/Light-Client\"},{\"title\":\"Creating a proposal\",\"order\":2,\"description\":null,\"href\":\"/cometbft/v0.38/spec/consensus/Creating-Proposal\"},{\"title\":\"BFT Time\",\"order\":2,\"description\":null,\"href\":\"/cometbft/v0.38/spec/consensus/BFT-Time\"},{\"order\":3,\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/spec/consensus/Proposer-Selection\"},{\"title\":\"Evidence\",\"order\":4,\"description\":null,\"href\":\"/cometbft/v0.38/spec/consensus/Evidence\"},{\"title\":\"Validator Signing\",\"order\":5,\"description\":null,\"href\":\"/cometbft/v0.38/spec/consensus/Validator-Signing\"},{\"title\":\"WAL\",\"order\":6,\"description\":null,\"href\":\"/cometbft/v0.38/spec/consensus/WAL\"}]},{\"group\":\"Light Client\",\"pages\":[{\"title\":\"Light Client Specification\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/spec/light-client/Light-Client-Specification\"},{\"order\":1,\"parent\":{\"title\":\"Verification\",\"order\":2},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/spec/light-client/verification\"},{\"order\":1,\"parent\":{\"title\":\"Fork Detection\",\"order\":2},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/spec/light-client/Fork-Detection\"},{\"order\":1,\"parent\":{\"title\":\"Accountability\",\"order\":4},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/spec/light-client/Accountability\"}]},{\"group\":\"P2P\",\"pages\":[{\"order\":1,\"parent\":{\"title\":\"P2P\",\"order\":6},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/Peer-to-Peer\"},{\"order\":1,\"title\":\"Implementation\",\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/Implementation-of-the-p2p-layer\"},{\"group\":\"Legacy Docs\",\"pages\":[{\"order\":1,\"title\":\"Legacy Docs\",\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/legacy-docs/Overview\"},{\"group\":\"Messages\",\"pages\":[{\"order\":1,\"parent\":{\"title\":\"Messages\",\"order\":1},\"title\":null,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/legacy-docs/messages/Overview\"},{\"title\":\"Block Sync\",\"order\":2,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/legacy-docs/messages/block-sync\"},{\"title\":\"Evidence\",\"order\":3,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/legacy-docs/messages/evidence\"},{\"title\":\"Mempool\",\"order\":4,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/legacy-docs/messages/mempool\"},{\"title\":\"State Sync\",\"order\":5,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/legacy-docs/messages/state-sync\"},{\"title\":\"Peer Exchange\",\"order\":6,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/legacy-docs/messages/Peer-Exchange\"},{\"title\":\"Consensus\",\"order\":7,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/legacy-docs/messages/consensus\"}]},{\"title\":\"P2P Multiplex Connection\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/legacy-docs/P2P-Multiplex-Connection\"},{\"title\":\"Peers\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/legacy-docs/Peers\"},{\"title\":\"P2P Config\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/legacy-docs/P2P-Config\"},{\"title\":\"Peer Discovery\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/legacy-docs/Peer-Discovery\"},{\"group\":\"Reactors\",\"pages\":[{\"title\":\"Reactors\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/reactor-api/Reactors\"},{\"title\":\"Reactor API\",\"order\":2,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/reactor-api/Reactor-Api\"},{\"title\":\"API for Reactors\",\"order\":3,\"description\":null,\"href\":\"/cometbft/v0.38/spec/p2p/reactor-api/API-for-Reactors\"}]}]}]},{\"group\":\"RPC\",\"pages\":[{\"title\":\"RPC spec\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/spec/rpc/Rpc-Spe\"}]},{\"group\":\"Blockchain\",\"pages\":[{\"title\":\"Blockchain\",\"order\":1,\"description\":null,\"href\":\"/cometbft/v0.38/spec/blockchain/Blockchain\"}]}]}]},{\"tab\":\"API Reference\",\"groups\":[{\"group\":\"Overview\",\"pages\":[{\"title\":\"CometBFT RPC\",\"description\":\"The RPC server provides an API for interacting with a CometBFT node, including blockchain data, transaction broadcasting, and node information.\",\"href\":\"/cometbft/v0.38/api-reference/rpc/index\"}]},{\"group\":\"RPC Methods\",\"pages\":[{\"group\":\"Tx\",\"pages\":[{\"title\":\"broadcast_tx_sync\",\"description\":\"Returns with the response from CheckTx. Does not wait for DeliverTx result.\\n\\nIf you want to be sure that the transaction is included in a block, you can\\nsubscribe for the result using JSONRPC via a websocket. See\\nhttps://docs.cosmos.network/cometbft/v0.38/docs/core/Subscribing-to-events-via-Websocket\\nIf you haven't received anything after a couple of blocks, resend it. If the\\nsame happens again, send it to some other node. A few reasons why it could\\nhappen:\\n\\n1. malicious node can drop or pretend it had committed your tx\\n2. malicious proposer (not necessary the one you're communicating with) can\\ndrop transactions, which might become valid in the future\\n(https://github.com/tendermint/tendermint/issues/3322)\\n\\n\\nPlease refer to [formatting/encoding rules](https://docs.cosmos.network/cometbft/v0.38/docs/core/Using-CometBFT#formatting)\\nfor additional details\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /broadcast_tx_sync\",\"href\":\"/cometbft/v0.38/api-reference/rpc/tx/broadcast_tx_sync\",\"autogeneratedByOpenApi\":true},{\"title\":\"broadcast_tx_async\",\"description\":\"Returns right away, with no response. Does not wait for CheckTx nor DeliverTx results.\\n\\nIf you want to be sure that the transaction is included in a block, you can\\nsubscribe for the result using JSONRPC via a websocket. See\\nhttps://docs.cosmos.network/cometbft/v0.38/docs/core/Subscribing-to-events-via-Websocket\\nIf you haven't received anything after a couple of blocks, resend it. If the\\nsame happens again, send it to some other node. A few reasons why it could\\nhappen:\\n\\n1. malicious node can drop or pretend it had committed your tx\\n2. malicious proposer (not necessary the one you're communicating with) can\\ndrop transactions, which might become valid in the future\\n(https://github.com/tendermint/tendermint/issues/3322)\\n3. node can be offline\\n\\nPlease refer to [formatting/encoding rules](https://docs.cosmos.network/cometbft/v0.38/docs/core/Using-CometBFT#formatting)\\nfor additional details\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /broadcast_tx_async\",\"href\":\"/cometbft/v0.38/api-reference/rpc/tx/broadcast_tx_async\",\"autogeneratedByOpenApi\":true},{\"title\":\"broadcast_tx_commit\",\"description\":\"Returns with the responses from CheckTx and DeliverTx.\\n\\nIMPORTANT: use only for testing and development. In production, use\\nBroadcastTxSync or BroadcastTxAsync. You can subscribe for the transaction\\nresult using JSONRPC via a websocket. See\\nhttps://docs.cosmos.network/cometbft/v0.38/docs/core/Subscribing-to-events-via-Websocket\\n\\nCONTRACT: only returns error if mempool.CheckTx() errs or if we timeout\\nwaiting for tx to commit.\\n\\nIf CheckTx or DeliverTx fail, no error will be returned, but the returned result\\nwill contain a non-OK ABCI code.\\n\\nPlease refer to [formatting/encoding rules](https://docs.cosmos.network/cometbft/v0.38/docs/core/Using-CometBFT#formatting)\\nfor additional details\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /broadcast_tx_commit\",\"href\":\"/cometbft/v0.38/api-reference/rpc/tx/broadcast_tx_commit\",\"autogeneratedByOpenApi\":true},{\"title\":\"check_tx\",\"description\":\"Checks the transaction without executing it.\\n\\nThe transaction won't be added to the mempool.\\n\\nPlease refer to [formatting/encoding rules](https://docs.cosmos.network/cometbft/v0.38/docs/core/Using-CometBFT#formatting)\\nfor additional details\\n\\nUpon success, the `Cache-Control` header will be set with the default\\nmaximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /check_tx\",\"href\":\"/cometbft/v0.38/api-reference/rpc/tx/check_tx\",\"autogeneratedByOpenApi\":true}]},{\"group\":\"Info\",\"pages\":[{\"title\":\"health\",\"description\":\"Node heartbeat\\n\\nGet node health. Returns empty result (200 OK) on success, no response - in case of an error.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /health\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/health\",\"autogeneratedByOpenApi\":true},{\"title\":\"status\",\"description\":\"Node Status\\n\\nGet CometBFT status including node info, pubkey, latest block hash, app hash, block height and time.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /status\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/status\",\"autogeneratedByOpenApi\":true},{\"title\":\"net_info\",\"description\":\"Network information\\n\\nGet network info.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /net_info\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/net_info\",\"autogeneratedByOpenApi\":true},{\"title\":\"blockchain\",\"description\":\"Get block headers (max: 20) for minHeight \u003c= height \u003c= maxHeight.\\n\\nGet block headers for minHeight \u003c= height \u003c= maxHeight.\\n\\nAt most 20 items will be returned.\\n\\nUpon success, the `Cache-Control` header will be set with the default\\nmaximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /blockchain\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/blockchain\",\"autogeneratedByOpenApi\":true},{\"title\":\"header\",\"description\":\"Get header at a specified height\\n\\nGet Header.\\n\\nIf the `height` field is set to a non-default value, upon success, the\\n`Cache-Control` header will be set with the default maximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /header\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/header\",\"autogeneratedByOpenApi\":true},{\"title\":\"header_by_hash\",\"description\":\"Get header by hash\\n\\nGet Header By Hash.\\n\\nUpon success, the `Cache-Control` header will be set with the default\\nmaximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /header_by_hash\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/header_by_hash\",\"autogeneratedByOpenApi\":true},{\"title\":\"block\",\"description\":\"Get block at a specified height\\n\\nGet Block.\\n\\nIf the `height` field is set to a non-default value, upon success, the\\n`Cache-Control` header will be set with the default maximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /block\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/block\",\"autogeneratedByOpenApi\":true},{\"title\":\"block_by_hash\",\"description\":\"Get block by hash\\n\\nGet Block By Hash.\\n\\nUpon success, the `Cache-Control` header will be set with the default\\nmaximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /block_by_hash\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/block_by_hash\",\"autogeneratedByOpenApi\":true},{\"title\":\"block_results\",\"description\":\"Get block results at a specified height\\n\\nGet block_results.\\n\\nIf the `height` field is set to a non-default value, upon success, the\\n`Cache-Control` header will be set with the default maximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /block_results\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/block_results\",\"autogeneratedByOpenApi\":true},{\"title\":\"commit\",\"description\":\"Get commit results at a specified height\\n\\nGet Commit.\\n\\nIf the `height` field is set to a non-default value, upon success, the\\n`Cache-Control` header will be set with the default maximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /commit\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/commit\",\"autogeneratedByOpenApi\":true},{\"title\":\"validators\",\"description\":\"Get validator set at a specified height\\n\\nGet Validators. Validators are sorted first by voting power\\n(descending), then by address (ascending).\\n\\nIf the `height` field is set to a non-default value, upon success, the\\n`Cache-Control` header will be set with the default maximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /validators\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/validators\",\"autogeneratedByOpenApi\":true},{\"title\":\"genesis\",\"description\":\"Get Genesis\\n\\nGet genesis.\\n\\nUpon success, the `Cache-Control` header will be set with the default\\nmaximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /genesis\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/genesis\",\"autogeneratedByOpenApi\":true},{\"title\":\"genesis_chunked\",\"description\":\"Get Genesis in multiple chunks\\n\\nGet genesis document in multiple chunks to make it easier to iterate\\nthrough larger genesis structures. Each chunk is produced by converting\\nthe genesis document to JSON and then splitting the resulting payload\\ninto 16MB blocks, and then Base64-encoding each block.\\n\\nUpon success, the `Cache-Control` header will be set with the default\\nmaximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /genesis_chunked\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/genesis_chunked\",\"autogeneratedByOpenApi\":true},{\"title\":\"dump_consensus_state\",\"description\":\"Get consensus state\\n\\nGet consensus state.\\n\\nNot safe to call from inside the ABCI application during a block execution.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /dump_consensus_state\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/dump_consensus_state\",\"autogeneratedByOpenApi\":true},{\"title\":\"consensus_state\",\"description\":\"Get consensus state\\n\\nGet consensus state.\\n\\nNot safe to call from inside the ABCI application during a block execution.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /consensus_state\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/consensus_state\",\"autogeneratedByOpenApi\":true},{\"title\":\"consensus_params\",\"description\":\"Get consensus parameters\\n\\nGet consensus parameters.\\n\\nIf the `height` field is set to a non-default value, upon success, the\\n`Cache-Control` header will be set with the default maximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /consensus_params\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/consensus_params\",\"autogeneratedByOpenApi\":true},{\"title\":\"unconfirmed_txs\",\"description\":\"Get the list of unconfirmed transactions\\n\\nGet list of unconfirmed transactions\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /unconfirmed_txs\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/unconfirmed_txs\",\"autogeneratedByOpenApi\":true},{\"title\":\"num_unconfirmed_txs\",\"description\":\"Get data about unconfirmed transactions\\n\\nGet data about unconfirmed transactions\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /num_unconfirmed_txs\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/num_unconfirmed_txs\",\"autogeneratedByOpenApi\":true},{\"title\":\"tx_search\",\"description\":\"Search for transactions\\n\\nSearch for transactions w/ their results.\\n\\nSee /subscribe for the query syntax.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /tx_search\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/tx_search\",\"autogeneratedByOpenApi\":true},{\"title\":\"block_search\",\"description\":\"Search for blocks by FinalizeBlock events\\n\\nSearch for blocks by FinalizeBlock events.\\n\\nSee /subscribe for the query syntax.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /block_search\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/block_search\",\"autogeneratedByOpenApi\":true},{\"title\":\"tx\",\"description\":\"Get transactions by hash\\n\\nGet a transaction\\n\\nUpon success, the `Cache-Control` header will be set with the default\\nmaximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /tx\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/tx\",\"autogeneratedByOpenApi\":true},{\"title\":\"broadcast_evidence\",\"description\":\"Broadcast evidence of the misbehavior.\\n\\nBroadcast evidence of the misbehavior.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /broadcast_evidence\",\"href\":\"/cometbft/v0.38/api-reference/rpc/info/broadcast_evidence\",\"autogeneratedByOpenApi\":true}]},{\"group\":\"Unsafe\",\"pages\":[{\"title\":\"dial_seeds\",\"description\":\"Dial Seeds (Unsafe)\\n\\nDial a peer, this route in under unsafe, and has to manually enabled to use\\n\\n  **Example:** curl 'localhost:26657/dial_seeds?seeds=\\\\[\\\"f9baeaa15fedf5e1ef7448dd60f46c01f1a9e9c4@1.2.3.4:26656\\\",\\\"0491d373a8e0fcf1023aaf18c51d6a1d0d4f31bd@5.6.7.8:26656\\\"\\\\]'\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /dial_seeds\",\"href\":\"/cometbft/v0.38/api-reference/rpc/unsafe/dial_seeds\",\"autogeneratedByOpenApi\":true},{\"title\":\"dial_peers\",\"description\":\"Add Peers/Persistent Peers (unsafe)\\n\\nSet a persistent peer, this route in under unsafe, and has to manually enabled to use.\\n\\n**Example:** curl 'localhost:26657/dial_peers?peers=\\\\[\\\"f9baeaa15fedf5e1ef7448dd60f46c01f1a9e9c4@1.2.3.4:26656\\\",\\\"0491d373a8e0fcf1023aaf18c51d6a1d0d4f31bd@5.6.7.8:26656\\\"\\\\]\u0026persistent=false'\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /dial_peers\",\"href\":\"/cometbft/v0.38/api-reference/rpc/unsafe/dial_peers\",\"autogeneratedByOpenApi\":true}]},{\"group\":\"ABCI\",\"pages\":[{\"title\":\"abci_info\",\"description\":\"Get info about the application.\\n\\nGet info about the application.\\n\\nUpon success, the `Cache-Control` header will be set with the default\\nmaximum age.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /abci_info\",\"href\":\"/cometbft/v0.38/api-reference/rpc/abci/abci_info\",\"autogeneratedByOpenApi\":true},{\"title\":\"abci_query\",\"description\":\"Query the application for some information.\\n\\nQuery the application for some information.\",\"deprecated\":null,\"version\":null,\"openapi\":\"cometbft/v0.38/api-reference/rpc/openapi.yaml get /abci_query\",\"href\":\"/cometbft/v0.38/api-reference/rpc/abci/abci_query\",\"autogeneratedByOpenApi\":true}]}]}]},{\"tab\":\"Release Notes\",\"pages\":[{\"title\":\"Release Notes\",\"description\":\"Release history and changelog for Cosmos CometBFT\",\"mode\":\"wide\",\"href\":\"/cometbft/v0.38/changelog/release-notes\"}]}]},{\"version\":\"next\",\"tag\":\"Unreleased\",\"tabs\":[{\"tab\":\"Learn\",\"groups\":[{\"group\":\"CometBFT\",\"pages\":[{\"noindex\":true,\"title\":\"CometBFT Documentation\",\"description\":\"CometBFT is a blockchain application platform.\",\"footer\":{\"newsletter\":false},\"href\":\"/cometbft/next/docs/README\"},{\"noindex\":true,\"order\":1,\"parent\":{\"title\":\"Introduction\",\"order\":1},\"title\":null,\"description\":null,\"href\":\"/cometbft/next/docs/introduction/intro\"},{\"group\":\"Guides\",\"pages\":[{\"noindex\":true,\"title\":\"Quick Start\",\"order\":2,\"description\":null,\"href\":\"/cometbft/next/docs/guides/Quick-Start\"},{\"noindex\":true,\"title\":\"Install CometBFT\",\"order\":3,\"description\":null,\"href\":\"/cometbft/next/docs/guides/Install-CometBFT\"},{\"noindex\":true,\"title\":\"Creating an application in Go\",\"order\":1,\"description\":null,\"href\":\"/cometbft/next/docs/guides/Creating-an-application-in-Go\"},{\"noindex\":true,\"title\":\"Creating a built-in application in Go\",\"order\":2,\"description\":null,\"href\":\"/cometbft/next/docs/guides/Creating-a-built-in-application-in-Go\"}]},{\"group\":\"Apps\",\"pages\":[{\"noindex\":true,\"title\":\"Getting Started\",\"order\":2,\"description\":null,\"href\":\"/cometbft/next/docs/app-dev/Getting-Started\"},{\"noindex\":true,\"title\":\"Application Architecture Guide\",\"order\":4,\"description\":null,\"href\":\"/cometbft/next/docs/app-dev/Application-Architecture-Guide\"},{\"noindex\":true,\"title\":\"Using ABCI-CLI\",\"order\":3,\"description\":null,\"href\":\"/cometbft/next/docs/app-dev/Using-ABCI-CLI\"},{\"noindex\":true,\"title\":\"Indexing Transactions\",\"order\":5,\"description\":null,\"href\":\"/cometbft/next/docs/app-dev/Indexing-Transactions\"}]},{\"group\":\"Core\",\"pages\":[{\"noindex\":true,\"title\":\"Using CometBFT\",\"order\":2,\"description\":null,\"href\":\"/cometbft/next/docs/core/Using-CometBFT\"},{\"noindex\":true,\"title\":\"Running in production\",\"order\":4,\"description\":null,\"href\":\"/cometbft/next/docs/core/Running-in-production\"},{\"noindex\":true,\"title\":\"Configuration\",\"order\":3,\"description\":null,\"href\":\"/cometbft/next/docs/core/configuration\"},{\"noindex\":true,\"title\":\"Mempool\",\"order\":12,\"description\":null,\"href\":\"/cometbft/next/docs/core/mempool\"},{\"noindex\":true,\"title\":\"Block Sync\",\"order\":10,\"description\":null,\"href\":\"/cometbft/next/docs/core/block-sync\"},{\"noindex\":true,\"title\":\"State Sync\",\"order\":11,\"description\":null,\"href\":\"/cometbft/next/docs/core/state-sync\"},{\"noindex\":true,\"title\":\"RPC\",\"order\":9,\"description\":null,\"href\":\"/cometbft/next/docs/core/RPC\"},{\"noindex\":true,\"title\":\"Subscribing to events via Websocket\",\"order\":7,\"description\":null,\"h