{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sniper.portfolio_target.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "portfolio_id",
    "environment",
    "portfolio_revision",
    "signal_version",
    "managed_universe_version",
    "signal_fingerprint",
    "as_of",
    "published_at",
    "replace_semantics",
    "capital_reference",
    "risk_envelope",
    "targets"
  ],
  "properties": {
    "portfolio_id": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "portfolio_revision": {
      "type": "integer",
      "minimum": 1
    },
    "signal_version": {
      "type": "string",
      "const": "sniper.portfolio_target.v1"
    },
    "managed_universe_version": {
      "type": "string",
      "minLength": 1
    },
    "signal_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "as_of": {
      "type": "string",
      "format": "date-time"
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "policy_name": {
      "type": "string"
    },
    "replace_semantics": {
      "type": "string",
      "const": "FULL_SNAPSHOT"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "capital_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "notional"
      ],
      "properties": {
        "currency": {
          "type": "string",
          "minLength": 1
        },
        "notional": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "risk_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_gross_weight"
      ],
      "properties": {
        "max_gross_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rebalance_band_bps": {
          "type": "integer",
          "minimum": 0
        },
        "min_order_notional_usd": {
          "type": "number",
          "minimum": 0
        },
        "cash_reserve_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "instrument_id",
          "target_weight"
        ],
        "properties": {
          "instrument_id": {
            "type": "string",
            "minLength": 1
          },
          "symbol": {
            "type": "string"
          },
          "target_weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "target_notional_usd": {
            "type": "number",
            "minimum": 0
          },
          "confidence": {
            "type": "number"
          },
          "p_meta": {
            "type": "number"
          },
          "regime": {
            "type": "string"
          }
        }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
